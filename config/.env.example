# TOP RECON — API keys. Copy to config/.env and fill what you have.
# Every key is optional: a module with no key simply shows "Needs Key" and is
# skipped. NEVER commit config/.env.

SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
ZOOMEYE_API_KEY=
HUNTER_API_KEY=
HIBP_API_KEY=
DEHASHED_API_KEY=
LEAKIX_API_KEY=
BUILTWITH_API_KEY=
URLSCAN_API_KEY=
CHECKPHISH_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
GITHUB_TOKEN=

# Google Custom Search (for the GOOGLE COMPARE view)
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# Scan tunables (optional)
TOPRECON_MAX_DEPTH=4
TOPRECON_WORKERS=24
TOPRECON_RATE_PER_MIN=1250
